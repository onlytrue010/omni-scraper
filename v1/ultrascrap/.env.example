# ── UltraScrap Environment Example ──────────────────────────
# Copy to .env and edit as needed

APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PORT=3000

# Scraper defaults
DEFAULT_CONCURRENCY=3
MAX_CONCURRENCY=20
DEFAULT_TIMEOUT=30
REQUEST_DELAY_MIN=1.0
REQUEST_DELAY_MAX=3.5

# Proxy (optional — comma-separated list of proxy URLs)
# Example: http://user:pass@proxy1.example.com:8080,http://proxy2:8080
PROXY_LIST=

# Rate control (AIMD + PID)
AIMD_INCREASE_STEP=0.5
AIMD_DECREASE_FACTOR=0.5
TARGET_ERROR_RATE=0.02

# Export
EXPORT_DIR=./exports
